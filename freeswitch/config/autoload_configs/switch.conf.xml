[settings]
debug = 0
log-level = INFO
log-file = /var/log/freeswitch/freeswitch.log
log-rotate = daily

[network]
sip-port = 5060
tls-sip-port = 5061
sip-ip = 0.0.0.0
tls-sip-ip = 0.0.0.0
local-network-acl = localnet

[core]
max-calls = 100
auto-create-schema = true
switchname = parking-ai-fs
log-sessions = true

[event_socket]
enabled = true
listen-ip = 0.0.0.0
listen-port = 8021
password = ClueCon

[http]
enabled = true
listen-ip = 0.0.0.0
listen-port = 8080